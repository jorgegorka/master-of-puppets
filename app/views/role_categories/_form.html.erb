<%= form_with(model: role_category, class: "form") do |f| %>
  <% if role_category.errors.any? %>
    <div class="form__errors" role="alert">
      <% role_category.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form__field">
    <%= f.label :name, "Category name" %>
    <%= f.text_field :name, autofocus: true, required: true, placeholder: "e.g. Orchestrator, Executor" %>
  </div>

  <div class="form__field">
    <%= f.label :description, "Description" %>
    <%= f.text_area :description, rows: 3, placeholder: "Brief description of this category's purpose" %>
  </div>

  <div class="form__field">
    <%= f.label :job_spec, "Job specification" %>
    <%= f.text_area :job_spec, rows: 15, required: true, placeholder: "Behavioral guidance appended to every role in this category..." %>
    <p class="form__hint">This specification is appended to each role's own job spec when building the agent prompt.</p>
  </div>

  <div class="form__actions">
    <%= f.submit class: "btn btn--primary" %>
  </div>
<% end %>
