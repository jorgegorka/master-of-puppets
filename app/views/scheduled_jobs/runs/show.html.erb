<% content_for :title, "Run – #{@run.scheduled_job.name}" %>

<section class="pad max-width">
  <h1>Run <%= @run.id %></h1>
  <p>Status: <span class="badge <%= @run.status_badge_modifier %>"><%= @run.status %></span></p>
  <p>Duration: <%= @run.duration_seconds %>s</p>
  <p>Cost: $<%= @run.cost_usd %> (<%= @run.prompt_tokens %> + <%= @run.completion_tokens %> tokens)</p>

  <h2>Output</h2>
  <% if @run.output_truncated_at_bytes.present? %>
    <p class="txt-subtle">
      Output truncated at <%= number_to_human_size(ScheduledJob::Runnable::MAX_OUTPUT_BYTES) %>
      (original size <%= number_to_human_size(@run.output_truncated_at_bytes) %>).
      The full transcript is available on the underlying chat session.
    </p>
  <% end %>
  <% if @run.output.to_s.strip.empty? %>
    <p class="txt-subtle">No output captured.</p>
  <% else %>
    <pre><%= @run.output %></pre>
  <% end %>

  <% if @run.failed? %>
    <h2>Error</h2>
    <pre><%= @run.error_message %></pre>
  <% end %>

  <% if @run.chat_session %>
    <%= link_to "Open underlying chat", @run.chat_session %>
  <% end %>
</section>
