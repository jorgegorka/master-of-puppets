<% content_for(:title, @skill.name) %>

<section class="skill-detail">
  <%# ── Profile header ── %>
  <header class="skill-detail__profile">
    <div class="skill-detail__profile-main">
      <h1 class="skill-detail__name"><%= @skill.name %></h1>
      <div class="skill-detail__meta">
        <code class="skill-detail__key"><%= @skill.key %></code>
        <% if @skill.category.present? %>
          <%= skill_category_badge(@skill.category) %>
        <% end %>
        <% if @skill.builtin? %>
          <span class="skill-card__builtin">built-in</span>
        <% else %>
          <span class="skill-card__custom">custom</span>
        <% end %>
      </div>
      <% if @skill.description.present? %>
        <p class="skill-detail__description"><%= @skill.description %></p>
      <% end %>
    </div>
    <div class="skill-detail__actions">
      <%= link_to "Edit", edit_skill_path(@skill), class: "btn btn--ghost btn--sm" %>
      <% unless @skill.builtin? %>
        <%= button_to "Delete", @skill, method: :delete, class: "btn btn--ghost btn--sm skill-detail__delete",
              data: { turbo_confirm: "Delete #{@skill.name}? This will remove it from all roles." } %>
      <% end %>
    </div>
  </header>

  <%# ── Two-column grid ── %>
  <div class="skill-detail__grid">

    <%# ── Primary column: Instructions ── %>
    <div class="skill-detail__primary">
      <div class="skill-detail__card">
        <h2 class="skill-detail__card-title">Instructions</h2>
        <div class="skill-detail__markdown">
          <%= simple_format(@skill.markdown) %>
        </div>
      </div>
    </div>

    <%# ── Sidebar column ── %>
    <div class="skill-detail__sidebar">
      <div class="skill-detail__card">
        <h2 class="skill-detail__card-title">Assigned Columns (<%= @columns.size %>)</h2>
        <% if @columns.any? %>
          <ul class="skill-detail__roles-list">
            <% @columns.each do |column| %>
              <li>
                <%= link_to column.name, column %>
                <span class="kanban__column-tag kanban__column-tag--<%= column.transition_policy %>">
                  <%= column.transition_policy %>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="skill-detail__empty-note">No columns have this skill assigned.</p>
        <% end %>
      </div>

      <div class="skill-detail__card">
        <h2 class="skill-detail__card-title">Documents</h2>
        <%= render "documents/document_picker",
              linkable: @skill,
              linked_documents: @skill_document_links,
              link_path: skill_skill_documents_path(@skill),
              unlink_path_helper: ->(skill, sd) { skill_skill_document_path(skill, sd) } %>
      </div>
    </div>
  </div>
</section>
