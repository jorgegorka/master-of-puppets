<% content_for :title, "Skills" %>

<%# `turbo_stream_from "skills"` MUST live outside the autocomplete-driven
    `skill-results` frame — every keystroke replaces that frame's contents,
    which would tear down the cable subscription. Keep it at the top. %>
<%= turbo_stream_from "skills" %>

<section class="pad max-width center">
  <header class="flex justify-between align-center">
    <h1>Skills</h1>
  </header>

  <%= form_with(url: skills_path, method: :get, local: true, class: "pad-block") do |f| %>
    <%= f.label :q, "Search skills…", for: "skills_q" %>
    <%= f.text_field :q,
          id: "skills_q",
          value: @query,
          placeholder: "skill name or body",
          data: {
            controller: "autocomplete",
            autocomplete_url_value: skills_path,
            autocomplete_frame_value: "skill-results",
            action: "input->autocomplete#update"
          } %>
    <%= f.submit "Search" %>
  <% end %>

  <%= turbo_frame_tag "skill-results", target: "_top" do %>
    <% if @skills.empty? && @query.present? %>
      <p class="txt-subtle">No skills matched <%= @query.inspect %>.</p>
    <% else %>
      <div id="skills_list">
        <%= render partial: "skills/list", locals: { skills_by_category: @skills.group_by(&:category) } %>
      </div>
    <% end %>
  <% end %>
</section>
