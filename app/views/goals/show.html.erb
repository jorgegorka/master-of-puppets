<% content_for(:title, @root_task.title) %>

<section class="goal-detail">
  <div class="goal-detail__header">
    <div class="goal-detail__header-top">
      <div>
        <h1 class="goal-detail__title"><%= @root_task.title %></h1>
        <div class="goal-detail__badges">
          <%= task_column_badge(@root_task) %>
          <% if @root_task.completed_at.present? %>
            <span class="goal-detail__completed-at">
              Completed <%= @root_task.completed_at.strftime("%b %d, %Y at %H:%M") %>
            </span>
          <% end %>
        </div>
      </div>
      <div class="goal-detail__actions">
        <%= link_to "Edit", edit_goal_path(@root_task), class: "btn btn--ghost btn--sm" %>
        <%= button_to "Delete", goal_path(@root_task), method: :delete, class: "btn btn--ghost btn--sm goal-detail__delete",
              data: { turbo_confirm: "Delete '#{@root_task.title}'?" } %>
      </div>
    </div>

    <% percentage = @root_task.completion_percentage %>
    <% subtasks = @root_task.subtasks.by_priority.includes(:parent_task, :column, :creator) %>
    <% completed_count = @root_task.subtasks.completed.count %>
    <div class="goal-detail__progress-card">
      <div class="goal-detail__progress-info">
        <span class="goal-detail__progress-label">Progress</span>
        <span class="goal-detail__progress-value"><%= percentage %>%</span>
      </div>
      <%= render "shared/progress_bar", percentage: percentage, large: true %>
      <div class="goal-detail__progress-stats">
        <span><%= percentage %>% complete &middot; <%= completed_count %> of <%= subtasks.size %> tasks done</span>
      </div>
    </div>
    <% if @root_task.recurring? %>
      <div class="goal-detail__recurrence">
        <span><%= Tasks::RecurrenceDescriber.new(@root_task).to_sentence %></span>
        <%= button_to "Stop recurrence", goal_recurrence_path(@root_task), method: :delete,
              class: "btn btn--ghost btn--xs",
              data: { turbo_confirm: "Stop recurrence for '#{@root_task.title}'?" } %>
      </div>
    <% end %>
  </div>

  <div class="goal-detail__body">
    <% if @root_task.summary.present? %>
      <div class="goal-detail__summary">
        <h2 class="goal-detail__summary-title">Outcome</h2>
        <%= markdown(@root_task.summary) %>
      </div>
    <% end %>

    <% if @root_task.description.present? %>
      <div class="goal-detail__description">
        <%= markdown(@root_task.description) %>
      </div>
    <% end %>

    <div class="goal-detail__section">
      <div class="goal-detail__section-header">
        <h2>Conversation <span class="goal-detail__count"><%= @root_task.messages.size %></span></h2>
      </div>
      <div class="message-thread">
        <% @detail.messages.each do |message| %>
          <%= render partial: "messages/thread", locals: { message: message, task: @root_task } %>
        <% end %>
        <% if @detail.messages.empty? %>
          <p class="goal-detail__empty-note">No messages yet.</p>
        <% end %>
      </div>
      <%= render "messages/form", task: @root_task, parent_id: nil %>
    </div>

    <div class="goal-detail__section">
      <div class="goal-detail__section-header">
        <h2>Tasks <span class="goal-detail__count"><%= subtasks.size %></span></h2>
        <%= link_to "+ Create task", new_task_path(parent_task_id: @root_task.id), class: "btn btn--primary btn--sm" %>
      </div>
      <% if subtasks.any? %>
        <div class="task-list">
          <% subtasks.each do |task| %>
            <%= render partial: "tasks/task", locals: { task: task } %>
          <% end %>
        </div>
      <% else %>
        <div class="goal-detail__empty">
          <p>No tasks yet. Create a task to start working toward this goal.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
