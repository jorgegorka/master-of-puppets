<%#
  Linear-style goal form. Mirrors tasks/_form.html.erb (hero title + pills)
  and adds an inline recurrence row specific to goals (root tasks).
%>
<%
  anchor_local = root_task.recurrence_anchor_at&.in_time_zone(root_task.recurrence_timezone || Current.user.timezone)
  recurring = root_task.recurring?
%>
<%= form_with(model: root_task,
              scope: :root_task,
              url: root_task.persisted? ? goal_path(root_task) : goals_path,
              class: "task-form",
              data: { turbo_frame: "_top" }) do |f| %>
  <% if root_task.errors.any? %>
    <div class="form__errors" role="alert">
      <p><strong><%= pluralize(root_task.errors.count, "error") %> prohibited this goal from being saved:</strong></p>
      <ul>
        <% root_task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_field :title,
        class: "task-form__title",
        required: true,
        autofocus: true,
        placeholder: "Goal title" %>

  <%= f.text_area :description,
        class: "task-form__description",
        rows: 3,
        placeholder: "Add a description…" %>

  <div class="task-form__pills"
       data-controller="goal-recurrence">
    <%= render "tasks/pill",
          form: f,
          attribute: :priority,
          icon: task_pill_icon(:priority),
          placeholder: "No priority",
          options: options_for_task_priority %>

    <button type="button"
            class="pill-btn"
            data-goal-recurrence-target="trigger"
            data-action="click->goal-recurrence#enable">
      <span class="pill-btn__icon" aria-hidden="true"><%= goal_pill_icon(:recurring) %></span>
      <span class="pill-btn__label">Recurring</span>
    </button>

    <%= hidden_field_tag :recurrent, recurring ? "1" : "0",
          data: { goal_recurrence_target: "flag" } %>

    <div class="goal-recurrence"
         data-goal-recurrence-target="row"
         <%= "hidden" unless recurring %>>
      <span class="goal-recurrence__icon" aria-hidden="true"><%= goal_pill_icon(:recurring) %></span>
      <span class="goal-recurrence__label">First due</span>
      <%= date_field_tag "recurrence[anchor_date]", anchor_local&.to_date,
            class: "goal-recurrence__date",
            data: { goal_recurrence_target: "date" } %>
      <%= hidden_field_tag "recurrence[anchor_hour]", anchor_local&.hour || 9 %>
      <span class="goal-recurrence__label">repeats every</span>
      <%= number_field_tag "recurrence[interval]", root_task.recurrence_interval || 1,
            min: 1, max: 365,
            class: "goal-recurrence__interval",
            data: { goal_recurrence_target: "interval" } %>
      <%= select_tag "recurrence[unit]",
            options_for_select([ %w[day day], %w[week week], %w[month month] ], root_task.recurrence_unit || "week"),
            class: "goal-recurrence__unit",
            data: { goal_recurrence_target: "unit" } %>
      <button type="button"
              class="goal-recurrence__clear"
              aria-label="Remove recurrence"
              data-action="click->goal-recurrence#clear">×</button>
    </div>
  </div>

  <div class="task-form__footer">
    <button type="button" class="btn btn--ghost" data-action="modal#close">Cancel</button>
    <%= f.submit root_task.persisted? ? "Update goal" : "Create goal", class: "btn btn--primary" %>
  </div>
<% end %>
