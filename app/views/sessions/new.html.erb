<% content_for :title, "Sign in" %>

<section class="pad-double max-width center">
  <%= form_with url: session_path, local: true, class: "flex flex-column gap auth-form" do |f| %>
    <h1>Sign in</h1>
    <% if flash[:alert] %>
      <p class="txt-negative" role="alert"><%= flash[:alert] %></p>
    <% end %>
    <label class="flex flex-column gap-half">
      <span>Email</span>
      <%= f.email_field :email, required: true, autocomplete: "email", autofocus: true %>
    </label>
    <label class="flex flex-column gap-half">
      <span>Password</span>
      <%= f.password_field :password, required: true, autocomplete: "current-password" %>
    </label>
    <%= f.submit "Sign in" %>
  <% end %>
</section>
