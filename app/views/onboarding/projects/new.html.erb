<% content_for(:title, "Create Your Project") %>

<section class="onboarding">
  <%= render "onboarding/progress" %>

  <div class="form-card glass">
    <h1>Create your project</h1>
    <p class="form-card__subtitle">A project is an isolated workspace where you'll configure a Kanban pipeline for your work.</p>

    <%= form_with(model: @project, url: onboarding_project_path, class: "form") do |f| %>
      <% if @project.errors.any? %>
        <div class="form__errors" role="alert">
          <% @project.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="form__field">
        <%= f.label :name, "Project name" %>
        <%= f.text_field :name, autofocus: true, required: true, placeholder: "e.g. Acme AI Corp" %>
      </div>

      <div class="form__field">
        <%= f.label :description, "Description (optional)" %>
        <%= f.text_area :description, rows: 3, placeholder: "What will this project do?" %>
      </div>

      <div class="form__actions">
        <%= f.submit "Continue", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</section>
