<% content_for(:title, "Continue") %>

<section class="onboarding">
  <%= render "onboarding/progress" %>

  <div class="onboarding__step">
    <h1>Your default columns are ready</h1>
    <p class="onboarding__subtitle">
      We've seeded your project with Backlog, In Progress, Review, Done, Blocked, and Cancelled columns.
      You can configure them after onboarding.
    </p>

    <%= form_with(url: onboarding_template_path, method: :post, class: "form") do |f| %>
      <div class="form__actions">
        <%= link_to "Back", new_onboarding_project_path, class: "btn btn--ghost" %>
        <%= f.submit "Continue", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</section>
