<% content_for(:title, "Configure Adapter") %>

<section class="onboarding">
  <%= render "onboarding/progress" %>

  <div class="form-card form-card--wide glass">
    <h1>Configure your default agent</h1>
    <p class="form-card__subtitle">
      Pick an adapter for the project's agent column. You can fine-tune each agent column's adapter later.
    </p>

    <%= form_with(url: onboarding_adapter_path, method: :post, class: "form") do |f| %>
      <div class="form__field">
        <%= f.label :adapter_type, "Adapter" %>
        <%= f.select :adapter_type,
              AdapterRegistry.adapter_types.map { |t| [AdapterRegistry.for(t).display_name, t] },
              { include_blank: "Select an adapter…" },
              { class: "form__select" } %>
      </div>

      <div class="form__field">
        <%= label_tag "adapter_config_model", "Model" %>
        <%= text_field_tag "adapter_config[model]", "claude-sonnet-4-20250514" %>
      </div>

      <div class="form__actions">
        <%= link_to "Back", new_onboarding_template_path, class: "btn btn--ghost" %>
        <%= f.submit "Continue", class: "btn btn--primary" %>
      </div>
    <% end %>
  </div>
</section>
