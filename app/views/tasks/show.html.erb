<% content_for(:title, @task.title) %>

<section class="task-detail">
  <div class="task-detail__header">
    <div>
      <h1><%= @task.title %></h1>
      <div class="task-detail__badges">
        <%= task_status_badge(@task) %>
        <%= task_priority_badge(@task) %>
      </div>
    </div>
    <div class="task-detail__actions">
      <%= link_to "Edit", edit_task_path(@task),
            class: "btn btn--ghost btn--sm",
            data: { turbo_frame: "task_form_modal" } %>
      <%= link_to "New Subtask", new_task_path(parent_task_id: @task.id),
            class: "btn btn--ghost btn--sm",
            data: { turbo_frame: "task_form_modal" } %>
      <%= button_to "Delete", @task, method: :delete, class: "btn btn--ghost btn--sm task-detail__delete",
            data: { turbo_confirm: "Delete '#{@task.title}'? This cannot be undone." } %>
    </div>
  </div>

  <%= turbo_frame_tag "task_form_modal" %>

  <% if @task.pending_review? %>
    <div class="task-detail__review-banner">
      <p>This task is <strong>pending review</strong>. Approve to mark complete, or reject with feedback.</p>
      <div class="task-detail__review-actions">
        <%= button_to "Approve", task_approval_path(@task), method: :patch, class: "btn btn--primary btn--sm",
              data: { turbo_confirm: "Approve this task?" } %>
        <%= button_to "Reject", task_rejection_path(@task), method: :patch, class: "btn btn--danger btn--sm",
              data: { turbo_confirm: "Reject this task?" } %>
      </div>
    </div>
  <% end %>

  <div class="task-detail__body">
    <% if @task.description.present? %>
      <div class="task-detail__section">
        <h2>Description</h2>
        <%= markdown_with_mentions(@task.description) %>
      </div>
    <% end %>

    <div class="task-detail__section">
      <h2>Details</h2>
      <dl class="task-detail__meta">
        <div class="task-detail__meta-row">
          <dt>Assignee</dt>
          <dd>
            <% if @task.assignee.present? %>
              <%= link_to @task.assignee.title, role_path(@task.assignee) %>
            <% else %>
              <span class="task-detail__unassigned">Unassigned</span>
            <% end %>
          </dd>
        </div>
        <% if @task.creator.present? %>
          <div class="task-detail__meta-row">
            <dt>Created by</dt>
            <dd><%= link_to @task.creator.title, role_path(@task.creator) %></dd>
          </div>
        <% end %>
        <div class="task-detail__meta-row">
          <dt>Created</dt>
          <dd><%= @task.created_at.strftime("%b %d, %Y at %H:%M") %></dd>
        </div>
        <% if @task.due_at.present? %>
          <div class="task-detail__meta-row">
            <dt>Due</dt>
            <dd><%= @task.due_at.strftime("%b %d, %Y at %H:%M") %></dd>
          </div>
        <% end %>
        <% if @task.completed_at.present? %>
          <div class="task-detail__meta-row">
            <dt>Completed</dt>
            <dd><%= @task.completed_at.strftime("%b %d, %Y at %H:%M") %></dd>
          </div>
        <% end %>
        <% if @task.cost_cents.present? %>
          <div class="task-detail__meta-row">
            <dt>Cost</dt>
            <dd><strong class="task-cost"><%= format_cents_as_dollars(@task.cost_cents) %></strong></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="task-detail__section">
      <h2>Documents</h2>
      <%= render "documents/document_picker",
            linkable: @task,
            linked_documents: @detail.document_links,
            link_path: task_task_documents_path(@task),
            unlink_path_helper: ->(task, td) { task_task_document_path(task, td) } %>
    </div>

    <% if @task.assignee.present? %>
      <div class="task-detail__section task-detail__workflow">
        <h2>Workflow Actions</h2>
        <%= render "task_delegations/form", task: @task %>
        <%= render "task_escalations/form", task: @task %>
        <% if delegation_targets_for(@task).empty? && !can_escalate?(@task) %>
          <p class="task-detail__empty-note">No delegation or escalation targets available for this assignee's position.</p>
        <% end %>
      </div>
    <% end %>

    <% if @detail.task_evaluations.any? %>
      <div class="task-detail__section">
        <h2>Task Evaluations</h2>
        <div class="eval-history">
          <% @detail.task_evaluations.each do |evaluation| %>
            <div class="eval-history__item eval-history__item--<%= evaluation.result %>">
              <div class="eval-history__header">
                <span class="eval-item__badge eval-item__badge--<%= evaluation.result %>">
                  <%= evaluation.result.upcase %>
                </span>
                <span class="eval-history__attempt">Attempt <%= evaluation.attempt_number %>/<%= TaskEvaluation::MAX_ATTEMPTS %></span>
                <time class="eval-history__time"><%= evaluation.created_at.strftime("%b %d, %Y at %H:%M") %></time>
              </div>
              <div class="eval-history__feedback"><%= markdown(evaluation.feedback) %></div>
              <div class="eval-history__meta">
                <span>Root task: <%= link_to evaluation.root_task.title, goal_path(evaluation.root_task) %></span>
                <% if evaluation.cost_cents.present? %>
                  <span>Cost: <%= format_cents_as_dollars(evaluation.cost_cents) %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="task-detail__section">
      <h2>Conversation (<%= @task.messages.size %>)</h2>
      <div class="message-thread">
        <% @detail.messages.each do |message| %>
          <%= render partial: "messages/thread", locals: { message: message, task: @task } %>
        <% end %>
        <% if @detail.messages.empty? %>
          <p class="task-detail__empty-note">No messages yet. Start the conversation below.</p>
        <% end %>
      </div>
      <%= render "messages/form", task: @task, parent_id: nil %>
    </div>

    <div class="task-detail__section">
      <h2>Audit Trail</h2>
      <% if @detail.audit_events.any? %>
        <ol class="audit-trail">
          <% @detail.audit_events.each do |event| %>
            <li class="audit-trail__event">
              <span class="audit-trail__action"><%= audit_event_description(event) %></span>
              <span class="audit-trail__meta">
                by <strong><%= event.actor.try(:email_address) || event.actor.try(:title) || "Unknown" %></strong>
              </span>
              <time class="audit-trail__time" datetime="<%= event.created_at.iso8601 %>">
                <%= time_ago_in_words(event.created_at) %> ago
              </time>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="task-detail__empty-note">No audit events recorded yet.</p>
      <% end %>
    </div>
  </div>
</section>
