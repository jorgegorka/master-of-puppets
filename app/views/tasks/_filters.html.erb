<%= form_with url: tasks_path, method: :get, class: "tasks-board__filters",
              data: { controller: "auto-submit" } do |f| %>
  <%= render "tasks/pill",
        form: f,
        attribute: :assignee_id,
        icon: task_pill_icon(:assignee),
        placeholder: "Any assignee",
        options: options_for_role_pill_select,
        searchable: true,
        current_value: params[:assignee_id],
        selected_label: @assignee_filter&.title %>

  <%= render "tasks/pill",
        form: f,
        attribute: :parent_task_id,
        icon: task_pill_icon(:parent_task),
        placeholder: "Any parent",
        options: Current.project.tasks.roots.order(:title).pluck(:title, :id),
        searchable: true,
        current_value: params[:parent_task_id],
        selected_label: @parent_filter&.title %>

  <label class="filter-toggle">
    <%= check_box_tag :overdue, "1", @overdue_filter, data: { action: "change->auto-submit#submit" } %>
    Overdue only
  </label>

  <label class="filter-toggle">
    <%= check_box_tag :show_cancelled, "1", @show_cancelled, data: { action: "change->auto-submit#submit" } %>
    Show cancelled
  </label>

  <% if request.query_string.present? %>
    <%= link_to "Clear", tasks_path, class: "btn btn--ghost btn--sm" %>
  <% end %>
<% end %>
