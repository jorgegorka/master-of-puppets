<% content_for :title, "Memory" %>

<section class="pad max-width center">
  <header class="flex justify-between align-center">
    <h1>Memory</h1>
    <%= link_to "Files", files_path, class: "btn" if respond_to?(:files_path) %>
  </header>

  <%= form_with url: memory_searches_path, method: :post, local: true, class: "pad-block" do |f| %>
    <%= f.search_field :query, placeholder: "Search memory…", "aria-label": "Search memory" %>
    <%= f.submit "Search" %>
  <% end %>

  <div class="grid grid-cols-2 gap">
    <aside aria-label="Memory tree">
      <h2 class="txt-small">Tree</h2>
      <% if @tree.empty? %>
        <p class="txt-subtle">No notes yet.</p>
      <% else %>
        <ul class="flex flex-column gap-quarter">
          <%= render partial: "memory/node", collection: @tree, as: :node %>
        </ul>
      <% end %>
    </aside>

    <aside aria-label="Recently changed">
      <h2 class="txt-small">Recently changed</h2>
      <% if @files.empty? %>
        <p class="txt-subtle">Nothing indexed yet.</p>
      <% else %>
        <ul class="flex flex-column gap-quarter">
          <% @files.each do |file| %>
            <li>
              <%= link_to file.title.presence || file.path, memory_file_path(file.path) %>
              <span class="txt-subtle txt-x-small">· <%= file.path %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </aside>
  </div>
</section>
