<% content_for :title, "Edit #{@file.path}" %>

<section class="pad max-width center">
  <header class="flex justify-between align-center">
    <h1><%= @file.title.presence || @file.path %></h1>
    <%= link_to "← Back", memory_path %>
  </header>

  <p class="txt-subtle txt-x-small">
    <%= @file.path %> · <%= number_to_human_size(@file.byte_size) %>
    · digest <code><%= @file.content_digest[0, 12] %></code>
  </p>

  <%= form_with url: memory_file_path(@file.path), method: :patch, local: true do |f| %>
    <%= f.label :content, "Body", class: "txt-small" %>
    <%= f.text_area :content, value: @file.body, rows: 30, cols: 80, "aria-label": "Body" %>
    <div class="flex gap pad-block-half">
      <%= f.submit "Save" %>
      <%= button_to "Delete", memory_file_path(@file.path), method: :delete, data: { turbo_confirm: "Delete #{@file.path}?" } %>
    </div>
  <% end %>

  <section class="pad-block" aria-label="Rendered preview">
    <h2 class="txt-small">Preview</h2>
    <article><%= simple_format(@file.body) %></article>
  </section>
</section>
