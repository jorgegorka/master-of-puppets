<% content_for :title, "Agent profiles" %>

<section class="pad max-width center">
  <header class="flex justify-between align-center">
    <h1>Agent profiles</h1>
    <div class="flex gap-half">
      <%= link_to "+ New profile", new_agent_profile_path, class: "btn" %>
      <%= button_to "Sync from YAML", agent_profiles_sync_path, method: :post, class: "btn btn-secondary" %>
    </div>
  </header>

  <% if flash[:notice] %><p role="status"><%= flash[:notice] %></p><% end %>
  <% if flash[:alert]  %><p role="alert"><%= flash[:alert] %></p><% end %>

  <% if @profiles.any? %>
    <ul class="flex flex-column gap-half">
      <% @profiles.each do |profile| %>
        <li class="pad-block-half flex justify-between align-center">
          <div>
            <%= link_to profile.display_name, agent_profile_path(profile) %>
            <span class="txt-subtle txt-x-small">
              <%= profile.role %> · <%= profile.model %>
            </span>
          </div>
          <span class="txt-x-small <%= profile.enabled? ? "txt-positive" : "txt-subtle" %>">
            <%= profile.enabled? ? "enabled" : "disabled" %>
          </span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="txt-subtle">No agent profiles yet. Click <em>Sync from YAML</em> to load the roster from <code>db/seeds/agent_profiles.yml</code>.</p>
  <% end %>
</section>
