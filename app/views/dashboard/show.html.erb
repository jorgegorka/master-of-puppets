<% content_for :title, "Dashboard" %>

<%= turbo_stream_from "dashboard:#{Current.user.id}" %>

<section class="pad max-width">
  <h1>Dashboard</h1>

  <%= render "rollups", rollup: @rollup %>

  <section class="recent-runs">
    <h2>Recent runs</h2>
    <%= render "recent_runs", runs: @recent_runs %>
  </section>

  <section class="mcp-status">
    <h2>MCP servers</h2>
    <%= render "mcp_status", mcp_servers: @mcp_servers %>
  </section>

  <section class="incidents">
    <h2>Incidents</h2>
    <ul class="card-list">
      <% @incidents.each do |ev| %>
        <li><%= ev.occurred_at.iso8601 %> — <code><%= ev.action %></code> — <%= ev.particulars.to_json.truncate(140) %></li>
      <% end %>
    </ul>
  </section>
</section>
