<% content_for(:title, "Dashboard") %>
<section class="dashboard">
  <%= turbo_stream_from "dashboard_project_#{Current.project.id}" %>
  <div class="dashboard__header">
    <div>
      <h1><%= @dashboard.name %></h1>
      <p class="dashboard__subtitle">Project command center</p>
    </div>
    <%= link_to "New Goal", new_goal_path, class: "btn btn--primary btn--sm" %>
  </div>

  <section id="dashboard-attention">
    <% if @dashboard.attention.any? %>
      <%= render "dashboard/attention_section", attention: @dashboard.attention %>
    <% end %>
  </section>

  <section class="goals-section">
    <h2 class="goals-section__title">Goals</h2>
    <div id="goals-list" class="goals-section__list">
      <% @dashboard.goals.each do |goal| %>
        <%= render "dashboard/goal_card", goal: goal %>
      <% end %>
    </div>
    <% unless @dashboard.goals.any? %>
      <p class="dashboard-empty" id="goals-empty">
        No goals yet. <%= link_to "Create a goal", new_goal_path %> to get started.
      </p>
    <% end %>
  </section>
</section>
