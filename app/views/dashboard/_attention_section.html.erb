<div class="attention-section">
  <h2 class="attention-section__title">
    Needs Your Attention
    <span class="attention-section__count"><%= attention.total_count %></span>
  </h2>

  <div class="attention-section__items">
    <% attention.tasks_pending_review.each do |task| %>
      <div class="attention-item">
        <span class="status-badge status-badge--pending_review">Review</span>
        <div class="attention-item__content">
          <%= link_to task.title, task_path(task), class: "attention-item__title" %>
          <span class="attention-item__context">
            <%= "subtask of #{task.parent_task.title}" if task.parent_task %>
          </span>
        </div>
      </div>
    <% end %>

    <% attention.blocked_tasks.each do |task| %>
      <div class="attention-item">
        <span class="status-badge status-badge--blocked">Blocked</span>
        <div class="attention-item__content">
          <%= link_to task.title, task_path(task), class: "attention-item__title" %>
          <span class="attention-item__context">
            <%= "subtask of #{task.parent_task.title}" if task.parent_task %>
          </span>
        </div>
      </div>
    <% end %>
  </div>
</div>
