<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Master of Puppets - AI orchestration made easy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Master of Puppets">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="author" content="Mario & Jorge Alvarez" />
    <meta name="view-transition" content="same-origin" />
    <meta name="color-scheme" content="dark light">
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if Current.user && Current.project %>
      <div class="app-layout" data-controller="sidebar">
        <%= render "layouts/sidebar" %>
        <div class="sidebar__backdrop" data-sidebar-target="backdrop" data-action="click->sidebar#closeDrawer"></div>

        <header class="app-topbar">
          <button class="topbar__hamburger" data-action="click->sidebar#openDrawer" type="button" aria-label="Open navigation">
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10zm0 5.25a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
            </svg>
          </button>
          <%= render "notifications/dropdown" %>
          <button type="button" class="theme-toggle" data-controller="theme" data-action="click->theme#toggle" aria-label="Toggle dark or light mode">
            <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="3.5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M10 1.5v2M10 16.5v2M1.5 10h2M16.5 10h2M4 4l1.4 1.4M14.6 14.6L16 16M4 16l1.4-1.4M14.6 5.4L16 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M16.5 12.5A7 7 0 017.5 3.5a7 7 0 109 9z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            </svg>
          </button>
          <%= render "layouts/project_switcher" %>
        </header>

        <div class="app-content">
          <% if notice %>
            <div class="flash flash--notice" role="status" data-controller="flash"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="flash flash--alert" role="alert" data-controller="flash"><%= alert %></div>
          <% end %>

          <main class="app-main">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <header class="app-topbar" style="justify-content: space-between;">
        <span class="sidebar__brand" style="border: none; padding: var(--space-3) var(--space-6);">
          <%= link_to "Master of Puppets", root_path, style: "color: var(--color-brand-500); text-decoration: none; font-weight: 800; font-size: var(--font-size-lg); letter-spacing: var(--letter-spacing-tight);" %>
        </span>
        <nav style="display: flex; align-items: center; gap: var(--space-3); padding-inline-end: var(--space-6);">
          <% if Current.user %>
            <%= render "layouts/project_switcher" %>
          <% else %>
            <%= link_to "Log in", new_session_path, class: "btn btn--ghost btn--sm" %>
            <%= link_to "Sign up", new_registration_path, class: "btn btn--primary btn--sm" %>
          <% end %>
        </nav>
      </header>

      <% if notice %>
        <div class="flash flash--notice" role="status" data-controller="flash"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash flash--alert" role="alert" data-controller="flash"><%= alert %></div>
      <% end %>

      <main class="app-main" style="margin-inline: auto;">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
