    <div class="sidebar__section" data-sidebar-target="section" data-section-id="dashboard">
      <button class="sidebar__toggle" data-action="click->sidebar#toggle" type="button">
        Dashboard
        <svg class="sidebar__chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
