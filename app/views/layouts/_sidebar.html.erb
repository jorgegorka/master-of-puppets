          <%= link_to "Overview", dashboard_path, class: "sidebar__link" %>
          <%= link_to "Tasks", tasks_path, class: "sidebar__link" %>
          <%= link_to "Activity", audit_logs_path, class: "sidebar__link" %>
          <% if safe_roles_path %>
            <%= link_to "Org Chart", safe_roles_path, class: "sidebar__link" %>
          <% end %>
          <%= link_to "Goals", goals_path, class: "sidebar__link" %>
        </div>
      </div>
    </div>

