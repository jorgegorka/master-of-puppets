#!/usr/bin/env ruby
require_relative "../config/environment"

api_token = ENV["DIRECTOR_API_TOKEN"]

unless api_token.present?
  $stderr.puts "DIRECTOR_API_TOKEN environment variable is required"
  exit 1
end

column = Column.find_by(api_token: api_token)

unless column
  $stderr.puts "No column found for the provided API token"
  exit 1
end

scope = (ENV["DIRECTOR_TOOL_SCOPE"].presence || "agent").to_sym

$stderr.puts "Director MCP server started for column: #{column.name} (#{column.project.name}) in #{scope} scope"

server = DirectorServer.new(column, tool_scope: scope)
server.run
