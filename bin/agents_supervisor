#!/usr/bin/env ruby
# Phase 4 supervisor v2:
#  - Bounded Concurrent::FixedThreadPool for handler dispatch
#    (was unbounded Thread.new(client) — DoS risk under tmux/MCP load).
#  - Per-connection MAX_RPC_LINE_BYTES line cap (default 64 KiB).
#  - Per-connection bad-parse rate cap (BAD_PARSE_CAP malformed lines
#    inside BAD_PARSE_WINDOW seconds → close).
#  - Single writer thread per connection: both inbound responses AND the
#    listener fan-out push onto a SizedQueue drained by one writer, so
#    notifications and RPC responses can never interleave on the wire.
#    Closes the Phase 2 TODO at line 99 of the old file.
#  - Socket path is env-configurable via MOP_SUPERVISOR_SOCKET so tests
#    can spin up a sandboxed supervisor.

require_relative "../config/environment"
require "socket"
require "json"
require "fileutils"
require "listen"
require "concurrent"
require "open3"

module AgentsSupervisor
  MAX_RPC_LINE_BYTES = Integer(ENV.fetch("MOP_RPC_MAX_LINE", 64 * 1024))
  BAD_PARSE_CAP      = Integer(ENV.fetch("MOP_RPC_BAD_PARSE_CAP", 5))
  BAD_PARSE_WINDOW   = Float(ENV.fetch("MOP_RPC_BAD_PARSE_WINDOW", 10))
  POOL_SIZE          = Integer(ENV.fetch("MOP_SUPERVISOR_POOL", 16))
  WRITE_QUEUE_SIZE   = 256
  SOCKET_PATH        = Pathname.new(ENV.fetch("MOP_SUPERVISOR_SOCKET", Rails.root.join("tmp/sockets/agents_supervisor.sock").to_s))

  # One ConnectionPump per accepted UNIX socket connection. Owns a reader
  # thread (parses incoming JSON-RPC lines, dispatches to the shared pool)
  # and a writer thread (drains the write queue to the wire). Notification
  # fan-out targets #notify which enqueues onto the same write queue, so
  # the wire format stays consistent under contention.
  class ConnectionPump
    def initialize(socket, dispatcher:, handler:, on_close:)
      @socket          = socket
      @dispatcher      = dispatcher
      @handler         = handler
      @on_close        = on_close
      @write_queue     = SizedQueue.new(WRITE_QUEUE_SIZE)
      @bad_parse_times = []
      @bad_parse_mu    = Mutex.new
      @closed          = false
      @close_mu        = Mutex.new
      @reader          = Thread.new { read_loop }
      @writer          = Thread.new { write_loop }
    end

    # Push a server-initiated notification (memory.changed / skills.changed)
    # through the same writer thread that owns the socket. Non-blocking; if
    # the consumer is so slow that the queue is full, close the connection
    # rather than block other consumers' fan-out.
    def notify(payload)
      return if closed?
      @write_queue.push(ensure_newline(payload), true)
    rescue ThreadError
      # SizedQueue#push(true) raises ThreadError when full.
      Rails.logger.warn("[supervisor] write queue full, closing slow consumer")
      close!
    rescue ClosedQueueError
      # Race with close!; ignore.
    end

    def close!
      @close_mu.synchronize do
        return if @closed
        @closed = true
      end
      # Mark the queue closed: pushes start raising ClosedQueueError, but
      # pops still drain any queued payloads (e.g. the final "line too long"
      # error response we want the client to see). Give the writer a brief
      # window to flush before yanking the socket out from under it.
      @write_queue.close rescue nil
      @writer.join(1) if @writer && Thread.current != @writer
      @socket.close rescue nil
      @on_close.call(self)
    end

    def closed?
      @close_mu.synchronize { @closed }
    end

    def join(timeout = nil)
      @reader.join(timeout)
      @writer.join(timeout)
    end

    private
      def read_loop
        until @socket.closed? || closed?
          line = @socket.gets("\n", MAX_RPC_LINE_BYTES)
          break if line.nil?
          if line.bytesize == MAX_RPC_LINE_BYTES && !line.end_with?("\n")
            push_response({ jsonrpc: "2.0", id: nil, error: { code: -32700, message: "line too long (max #{MAX_RPC_LINE_BYTES} bytes)" } }.to_json)
            break
          end
          stripped = line.strip
          next if stripped.empty?

          @dispatcher.post do
            response = handle_one(stripped)
            push_response(response) if response
          end
        end
      rescue IOError, Errno::EPIPE, Errno::ECONNRESET
        # connection gone
      ensure
        close!
      end

      def write_loop
        while (payload = pop_next)
          begin
            @socket.write(payload)
          rescue IOError, Errno::EPIPE, Errno::ECONNRESET
            break
          end
        end
      ensure
        close!
      end

      def pop_next
        @write_queue.pop
      rescue ClosedQueueError
        nil
      end

      def push_response(payload)
        return if closed?
        @write_queue.push(ensure_newline(payload))
      rescue ClosedQueueError
        nil
      end

      def ensure_newline(payload)
        payload.end_with?("\n") ? payload : "#{payload}\n"
      end

      def handle_one(line)
        request = JSON.parse(line)
        @handler.call(request).to_json
      rescue JSON::ParserError
        if register_bad_parse_and_check_cap
          close!
          nil
        else
          { jsonrpc: "2.0", id: nil, error: { code: -32700, message: "parse error" } }.to_json
        end
      rescue => e
        Rails.logger.error("[supervisor] handler raised: #{e.class}: #{e.message}")
        { jsonrpc: "2.0", id: nil, error: { code: -32603, message: "internal error" } }.to_json
      end

      def register_bad_parse_and_check_cap
        @bad_parse_mu.synchronize do
          now = Time.now.to_f
          @bad_parse_times.reject! { |t| now - t > BAD_PARSE_WINDOW }
          @bad_parse_times << now
          @bad_parse_times.size >= BAD_PARSE_CAP
        end
      end
  end

  # Owns the tmux side of terminal sessions. Every shell command goes
  # through array-form Open3 (no shell metachar interpolation). The Rails
  # web process is responsible for tailing the FIFO and broadcasting back
  # to TerminalChannel subscribers — that pump can't live here because
  # the dev/test cable adapters are in-process and a broadcast from this
  # subprocess would never reach the web process.
  class TmuxBridge
    FIFO_DIR = Rails.root.join("tmp/sockets")

    def initialize
      FileUtils.mkdir_p(FIFO_DIR)
    end

    def create(session_id:, cwd:, cols:, rows:, **)
      name = name_for(session_id)
      run!("tmux", "new-session", "-d", "-s", name, "-x", cols.to_s, "-y", rows.to_s, "-c", cwd)
      fifo = fifo_path(session_id)
      File.mkfifo(fifo.to_s) unless fifo.exist?
      # pipe-pane's shell argument is the only string-interpolated bit; the
      # FIFO path is server-derived from an integer session_id, not user input.
      run!("tmux", "pipe-pane", "-t", name, "-o", "cat >> #{fifo}")
      { tmux_session_name: name, fifo: fifo.to_s }
    end

    def input(session_id:, data:, **)
      run!("tmux", "send-keys", "-t", name_for(session_id), "-l", data.to_s)
      { ok: true }
    end

    def resize(session_id:, cols:, rows:, **)
      run!("tmux", "resize-window", "-t", name_for(session_id), "-x", cols.to_s, "-y", rows.to_s)
      { ok: true }
    end

    def close(session_id:, **)
      out, status = Open3.capture2e("tmux", "kill-session", "-t", name_for(session_id))
      fifo = fifo_path(session_id)
      File.unlink(fifo.to_s) if fifo.exist?
      # kill-session failing usually means "no such session" — already gone,
      # so the desired end state is satisfied. Bubble other failures up.
      unless status.success?
        return { ok: true, note: "session not found" } if out.include?("can't find session") || out.include?("no server")
        raise "tmux kill-session failed: #{out}"
      end
      { ok: true }
    end

    def capture(session_id:, lines: 500, **)
      out, status = Open3.capture2e("tmux", "capture-pane", "-p", "-t", name_for(session_id), "-S", "-#{lines.to_i}")
      raise "tmux capture-pane failed: #{out}" unless status.success?
      { text: out }
    end

    def fifo_path(session_id)
      FIFO_DIR.join("term-#{session_id}.fifo")
    end

    private
      def name_for(session_id)
        "mop-term-#{session_id}"
      end

      def run!(*argv)
        out, status = Open3.capture2e(*argv)
        raise "tmux command failed: #{argv.inspect}\n#{out}" unless status.success?
        out
      end
  end
end

# ---- Boot ------------------------------------------------------------------

socket_path = AgentsSupervisor::SOCKET_PATH
FileUtils.mkdir_p(socket_path.dirname)
File.delete(socket_path) if File.exist?(socket_path)

server = UNIXServer.new(socket_path.to_s)
# SECURITY: 0600 keeps other local UIDs from connecting. Peer-credential
# auth (SO_PEERCRED on Linux, getpeereid on macOS) is the proper gate
# once Phase 4 layers tmux + MCP spawns onto this socket; until then
# filesystem perms are the only thing between an unprivileged process
# and `memory.changed` paths leaking + RPC commands executing.
File.chmod(0o600, socket_path.to_s)

shutdown_r, shutdown_w = IO.pipe
connections            = Concurrent::Array.new
dispatcher             = Concurrent::FixedThreadPool.new(AgentsSupervisor::POOL_SIZE)

Rails.logger.info("[agents_supervisor] listening on #{socket_path} (pool=#{AgentsSupervisor::POOL_SIZE})")
puts "[agents_supervisor] listening on #{socket_path}"

# Trap handlers must avoid I/O on Rails.logger (writing from a trap context
# can deadlock or segfault on Ruby 3.x). Signal the main thread by closing a
# pipe, which IO.select picks up.
trap("TERM") { shutdown_w.close rescue nil }
trap("INT")  { shutdown_w.close rescue nil }

memory_root = Pathname.new(Rails.application.config.x.mop_home).join("memory")
FileUtils.mkdir_p(memory_root)

broadcast = lambda do |payload|
  connections.each { |conn| conn.notify(payload) }
end

listener = Listen.to(memory_root.to_s, only: /\.md\z/, latency: 0.5) do |modified, added, removed|
  paths = (modified + added + removed).map { |abs| Pathname.new(abs).relative_path_from(memory_root).to_s }
  broadcast.call({ jsonrpc: "2.0", method: "memory.changed", params: { paths: paths } }.to_json)
end
listener.start

skills_root = Pathname.new(Rails.application.config.x.mop_home).join("skills")
FileUtils.mkdir_p(skills_root)

skills_listener = Listen.to(skills_root.to_s, only: /SKILL\.md\z/, latency: 0.5) do |modified, added, removed|
  paths = (modified + added + removed).map { |abs| abs.to_s }
  broadcast.call({ jsonrpc: "2.0", method: "skills.changed", params: { paths: paths } }.to_json)
end
skills_listener.start

tmux = AgentsSupervisor::TmuxBridge.new

handle_request = lambda do |request|
  method = request["method"]
  params = (request["params"] || {}).transform_keys(&:to_sym)
  result =
    case method
    when "health.ping"     then { pong: true, pid: Process.pid }
    when "terminal.create" then tmux.create(**params)
    when "terminal.input"  then tmux.input(**params)
    when "terminal.resize" then tmux.resize(**params)
    when "terminal.close"  then tmux.close(**params)
    when "terminal.capture" then tmux.capture(**params)
    else
      return { jsonrpc: "2.0", id: request["id"], error: { code: -32601, message: "method not found: #{method}" } }
    end
  { jsonrpc: "2.0", id: request["id"], result: result }
rescue => e
  Rails.logger.error("[supervisor] #{method}: #{e.class}: #{e.message}")
  { jsonrpc: "2.0", id: request["id"], error: { code: -32603, message: "#{e.class}: #{e.message}" } }
end

remove_connection = lambda do |conn|
  connections.delete(conn)
end

loop do
  readable, = IO.select([ server, shutdown_r ])

  if readable.include?(shutdown_r)
    Rails.logger.info("[agents_supervisor] shutting down") rescue nil
    listener.stop rescue nil
    skills_listener.stop rescue nil
    connections.each(&:close!)
    dispatcher.shutdown
    dispatcher.wait_for_termination(5)
    server.close rescue nil
    File.unlink(socket_path) rescue nil
    exit 0
  end

  client = server.accept_nonblock(exception: false)
  next if client == :wait_readable

  pump = AgentsSupervisor::ConnectionPump.new(
    client,
    dispatcher: dispatcher,
    handler:    handle_request,
    on_close:   remove_connection
  )
  connections << pump
end
